<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>


<StackPane xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" 
           stylesheets="@/css/table-style.css" fx:id="rootPane">
              
    <!-- Background Image -->
    <ImageView fx:id="bgImage" preserveRatio="false" fitHeight="600" fitWidth="1000">
        <image>
            <Image url="@/assets/login_bg.jpg"/>
        </image>
    </ImageView>

    <!-- Foreground layout -->
    <VBox alignment="TOP_CENTER" spacing="15.0" maxWidth="1000">
        <padding>
            <Insets top="20" right="20" bottom="20" left="20"/>
        </padding>

        <!-- Top Menu and Logout -->
        <HBox alignment="CENTER_RIGHT" spacing="20">
            <MenuBar fx:id="menu" style="-fx-background-color: white;">
                <menus>
                    <Menu fx:id="profile" text="Profile">
                        <items>
                            <MenuItem fx:id="viewProfile" text="View my profile" onAction="#handleViewProfile"/>
                            <MenuItem fx:id="updateProfile" text="Update my profile" onAction="#handleUpdateProfile"/>
                        </items>
                    </Menu>
                </menus>
            </MenuBar>
            <Button fx:id="logoutButton" text="Logout"
                    onAction="#handleLogout"
                    style="-fx-background-color: #e63946; -fx-text-fill: white; -fx-font-weight: bold;"/>
        </HBox>

        <!-- Welcome Message -->
        <VBox alignment="CENTER" spacing="5">
            <Label fx:id="welcomeLabel" text="Welcome,"
                   style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white;"
                   maxWidth="Infinity" alignment="CENTER"/>
            <Label text="These are the events available for booking:"
                   style="-fx-font-size: 16px; -fx-text-fill: white;"
                   maxWidth="Infinity" alignment="CENTER"/>
        </VBox>

        <!-- Events Table -->
        <HBox alignment="CENTER">
            <TableView fx:id="eventTable"  prefWidth="1000" style="-fx-background-color: white; -fx-border-color: lightgray;">
                <columns>
                    <TableColumn fx:id="eventnameColumn" text="Event Name" prefWidth="200"/>
                    <TableColumn fx:id="venueColumn" text="Venue" prefWidth="200"/>
                    <TableColumn fx:id="dayOfWeekColumn" text="Day" prefWidth="150"/>
                    <TableColumn fx:id="priceColumn" text="Price" prefWidth="150"/>
                    <TableColumn fx:id="ticketsSoldColumn" text="Tickets Sold" prefWidth="150"/>
                    <TableColumn fx:id="totalTicketsColumn" text="Total Tickets" prefWidth="150"/>
                </columns>
            </TableView>
        </HBox>

       <!-- Buttons for Add to Cart, View Cart and View Orders -->
		<HBox alignment="CENTER" spacing="20">
		    <Button fx:id="addToCartButton"
		            text="Add to Cart"
		            onAction="#handleAddToCart"
		            style="-fx-background-color: #1d3557; -fx-text-fill: white; -fx-font-weight: bold;"/>
		    <HBox spacing="5" alignment="CENTER">
		        <Button fx:id="viewCartButton"
		                text="🛒 View Cart"
		                onAction="#handleCartView"
		                style="-fx-background-color: #457b9d; -fx-text-fill: white; -fx-font-weight: bold;"/>
		        <Label fx:id="cartCountLabel" 
		               text="(0)" 
		               style="-fx-text-fill: white; -fx-font-weight: bold;"/>
		    </HBox>
		    <Button fx:id="viewOrdersButton"
		            text="View Orders"
		            onAction="#handleViewOrders"
		            style="-fx-background-color: #457b9d; -fx-text-fill: white; -fx-font-weight: bold;"/>
		</HBox>
    </VBox>

</StackPane>
